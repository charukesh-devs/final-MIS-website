# Port configuration (default 3000)
PORT=3000

# CORS Configuration - Set this to the exact Netlify production URL
FRONTEND_URL=http://localhost:3000

# Supabase Credentials (from your Supabase Dashboard -> Settings -> API)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret - Used to verify tokens if custom session management is implemented
JWT_SECRET=your_jwt_secret_key_change_me_in_production
